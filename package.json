{
  "name": "@phoenixtw/awsps",
  "version": "0.0.0",
  "description": "Interactive AWS profile switcher with SSO login, alias shortcuts, and shell hooks",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "awsps": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "aws",
    "profile",
    "switcher",
    "sso",
    "cli",
    "awsps"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/phoenixTW/aws-profile-switcher"
  },
  "author": {
    "name": "Kaustav Chakraborty",
    "email": "kaustav.chakraborty@iamkaustav.com",
    "url": "https://iamkaustav.com"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@smithy/shared-ini-file-loader": "^4.4.0",
    "commander": "^14.0.0",
    "env-paths": "^3.0.0",
    "execa": "^9.0.0",
    "fuse.js": "^7.0.0",
    "picocolors": "^1.1.0",
    "proper-lockfile": "^4.1.2",
    "shescape": "^2.0.0",
    "write-file-atomic": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.0.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
